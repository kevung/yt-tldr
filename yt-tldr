#!/usr/bin/env python3
"""yt-tldr: Summarize a YouTube video transcript using Claude Haiku via claude CLI."""

import sys
import re
import subprocess
import tempfile
import os
import glob


def extract_video_id(url: str) -> str:
    patterns = [
        r"(?:v=|youtu\.be/)([A-Za-z0-9_-]{11})",
        r"(?:embed/|shorts/)([A-Za-z0-9_-]{11})",
    ]
    for pattern in patterns:
        m = re.search(pattern, url)
        if m:
            return m.group(1)
    # Treat the input as a bare video ID if it looks like one
    if re.fullmatch(r"[A-Za-z0-9_-]{11}", url):
        return url
    raise ValueError(f"Could not extract video ID from: {url}")


def parse_vtt(vtt_text: str) -> str:
    """Extract plain text from a WebVTT subtitle file, deduplicating overlapping lines."""
    lines = vtt_text.splitlines()
    seen = []
    for line in lines:
        # Skip header, timing lines, and empty lines
        if (not line.strip()
                or line.startswith("WEBVTT")
                or line.startswith("Kind:")
                or line.startswith("Language:")
                or re.match(r"\d{2}:\d{2}:\d{2}\.\d{3} -->", line)):
            continue
        # Strip inline word-level timestamps: <00:00:01.230> and <c>, </c>
        line = re.sub(r"<\d{2}:\d{2}:\d{2}\.\d{3}>", "", line)
        line = re.sub(r"</?c>", "", line)
        line = line.strip()
        if not line:
            continue
        # Skip sound descriptions like [Music], [Applause], etc.
        if re.fullmatch(r"\[.*?\]", line):
            continue
        # Deduplicate: YouTube VTT repeats the growing line on each word
        if not seen or seen[-1] != line:
            seen.append(line)
    return " ".join(seen)


def fetch_transcript(url: str) -> str:
    with tempfile.TemporaryDirectory() as tmpdir:
        output_template = os.path.join(tmpdir, "sub")
        result = subprocess.run(
            [
                "yt-dlp",
                "--write-auto-subs",
                "--skip-download",
                "--sub-langs", "en.*",
                "--sub-format", "vtt",
                "--no-warnings",
                "-o", output_template,
                url,
            ],
            capture_output=True,
            text=True,
        )
        vtt_files = glob.glob(os.path.join(tmpdir, "*.vtt"))
        if not vtt_files:
            # Re-raise yt-dlp's stderr as an error message
            raise RuntimeError(
                result.stderr.strip()
                or "yt-dlp did not produce any subtitle files. "
                   "The video may not have captions."
            )
        # Prefer non-auto-generated if both exist; otherwise take any
        preferred = [f for f in vtt_files if ".en." in os.path.basename(f)
                     and ".en-orig." not in os.path.basename(f)]
        vtt_path = preferred[0] if preferred else vtt_files[0]
        with open(vtt_path, encoding="utf-8") as f:
            return parse_vtt(f.read())


def summarize(transcript: str) -> str:
    prompt = (
        "Please provide a concise summary of the following YouTube video transcript. "
        "Highlight the key points and main takeaways.\n\n"
        f"TRANSCRIPT:\n{transcript}"
    )
    result = subprocess.run(
        [
            "claude",
            "--model", "claude-haiku-4-5-20251001",
            "--print",
            prompt,
        ],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print(result.stderr, file=sys.stderr)
        sys.exit(result.returncode)
    return result.stdout.strip()


def main():
    if len(sys.argv) != 2 or sys.argv[1] in ("-h", "--help"):
        print("Usage: yt-tldr <youtube-url>", file=sys.stderr)
        sys.exit(0 if sys.argv[1:] and sys.argv[1] in ("-h", "--help") else 1)

    url = sys.argv[1]
    # Validate it looks like a YouTube URL or video ID
    try:
        extract_video_id(url)
    except ValueError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    try:
        transcript = fetch_transcript(url)
    except RuntimeError as e:
        print(f"Error fetching transcript: {e}", file=sys.stderr)
        sys.exit(1)

    if not transcript.strip():
        print("Error: transcript is empty.", file=sys.stderr)
        sys.exit(1)

    summary = summarize(transcript)
    print(summary)


if __name__ == "__main__":
    main()
